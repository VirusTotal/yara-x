{
  "name": "@virustotal/yara-x-ls-web",
  "version": "1.14.0",
  "description": "Browser worker packaging for the YARA-X language server",
  "license": "BSD-3-Clause",
  "homepage": "https://virustotal.github.io/yara-x",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VirusTotal/yara-x.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "pkg",
    "README.md",
    "index.js",
    "index.d.ts",
    "worker.js"
  ],
  "scripts": {
    "build:web": "cd ../ls && wasm-pack build --profile=wasm-release-lto --mode no-install --no-pack --target web --out-dir ../ls-wasm/pkg",
    "prepack": "npm run build:web && rm -f pkg/.gitignore",
    "test:js": "node --test tests-js/*.test.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "lsp",
    "language-server",
    "cybersecurity",
    "malware",
    "yara"
  ]
}
