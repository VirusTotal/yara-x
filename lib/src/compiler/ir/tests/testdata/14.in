import "pe"

rule test_1 {
    condition:
        for any i in (1..5) : (
            for any j in (1..5) : (
                for any k in (1..5) : (
                    pe.number_of_sections > 0 or i == 3 or j == 4
                )
            )
        )
}

rule test_2 {
    condition:
        with x = 10 : (
            for any i in (1..5) : (
                x + 1 == 11 and i > 0
            )
        )
}

rule test_3 {
    condition:
        for any i in (0..pe.number_of_sections) : (
            pe.sections[i].name == ".text" and pe.number_of_sections > 0
        )
}

