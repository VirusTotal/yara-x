rule long_hex_seq {
	strings:
		$h = { (
			2D A? FF FF FF ?? ?? |
			2D B? FF FF FF ?? ?? |
			2D C? FF FF FF ?? ?? |
			2D D? FF FF FF ?? ?? |
			81 E? ( A? | B? | C? | D? ) FF FF FF ?? ?? |
			6A 2? 03 ?? 24 ( 58 | 59 | 5A | 5B | 5D | 5E | 5F ) ?? ?? |
			6A 3? 03 ?? 24 ( 58 | 59 | 5A | 5B | 5D | 5E | 5F ) ?? ?? |
			6A 4? 03 ?? 24 ( 58 | 59 | 5A | 5B | 5D | 5E | 5F ) ?? ?? |
			6A 5? 03 ?? 24 ( 58 | 59 | 5A | 5B | 5D | 5E | 5F ) ?? ?? |
			83 B? ( 2? | 3? | 4? | 5? ) ?? ?? |
			83 C? ( 2? | 3? | 4? | 5? ) ?? ?? |
	        83 D? ( 2? | 3? | 4? | 5? ) ?? ?? |
			8D 4? ( 2? | 3? | 4? | 5? ) ?? ?? |
			8D 5? ( 2? | 3? | 4? | 5? ) ?? ?? |
			8D 6? ( 2? | 3? | 4? | 5? ) ?? ?? |
			8D 7? ( 2? | 3? | 4? | 5? ) ?? ?? |
			8D 8? ( 2? | 3? | 4? | 5? ) ?? ?? ) }
	condition:
		$h
}