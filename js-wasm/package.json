{
  "name": "yara-x",
  "version": "0.1.0",
  "description": "WebAssembly build of yara-x with browser-friendly JavaScript APIs.",
  "type": "module",
  "sideEffects": false,
  "main": "./pkg/yara_x_js.js",
  "module": "./pkg/yara_x_js.js",
  "types": "./pkg/yara_x_js.d.ts",
  "exports": {
    ".": {
      "types": "./pkg/yara_x_js.d.ts",
      "import": "./pkg/yara_x_js.js",
      "default": "./pkg/yara_x_js.js"
    },
    "./bundle": "./dist/yara_x_js_bundle.min.js",
    "./bundle-dev": "./dist/yara_x_js_bundle.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "pkg/**/*",
    "README.md"
  ],
  "scripts": {
    "build:web": "cargo build-web-release",
    "prepack": "npm run build:web",
    "test:wasm-node": "wasm-pack test --node --profile wasm-dev --test wasm_api --test wasm_modules -- --nocapture",
    "test:wasm-browser": "wasm-pack test --headless --chrome --profile wasm-dev --test wasm_browser_api -- --nocapture",
    "test:wasm": "npm run test:wasm-node && npm run test:wasm-browser",
    "test:js": "node --test tests-js/*.test.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "yara",
    "yara-x",
    "wasm",
    "webassembly",
    "malware"
  ]
}
